{
  "name": "survey-kklp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4174",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "build:aapanel": "cross-env VITE_USE_LOCAL_API=true NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "predeploy:jamkesfktp": "cross-env VITE_BASE_URL=/ NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "deploy:jamkesfktp": "npm run predeploy:jamkesfktp && node -e \"require('fs').writeFileSync('dist/CNAME', 'jamkesfktp.web.id')\" && gh-pages -d dist",
    "predeploy:riki": "cross-env VITE_BASE_URL=/surveyKLP/ NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "deploy:riki": "npm run predeploy:riki && gh-pages -d dist --repo https://github.com/Riki171415/surveyKLP.git",
    "deploy:all": "npm run deploy:jamkesfktp && npm run deploy:riki"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.16.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  }
}
